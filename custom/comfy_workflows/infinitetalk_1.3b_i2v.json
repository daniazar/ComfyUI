{
  "1": {
    "inputs": {
      "model": "wan2.1/wan2.1-i2v-14b-480p-Q4_K_M.gguf",
      "base_precision": "fp16",
      "load_device": "main_device",
      "quantization": "disabled"
    },
    "class_type": "WanVideoModelLoader",
    "_meta": { "title": "WanVideo Model Loader" }
  },
  "2": {
    "inputs": {
      "model": "TencentGameMate/chinese-wav2vec2-base",
      "base_precision": "fp16",
      "load_device": "main_device"
    },
    "class_type": "DownloadAndLoadWav2VecModel",
    "_meta": { "title": "Load Wav2Vec (Audio Encoder)" }
  },
  "3": {
    "inputs": {
      "model_name": "t5_xxl",
      "precision": "bf16",
      "load_device": "offload_device"
    },
    "class_type": "DownloadAndLoadWanVideoT5TextEncoder",
    "_meta": { "title": "Load T5 Text Encoder" }
  },
  "4": {
    "inputs": {
      "model_name": "Wan2_1_VAE_bf16.safetensors",
      "precision": "bf16"
    },
    "class_type": "WanVideoVAELoader",
    "_meta": { "title": "Load VAE" }
  },
  "5": {
    "inputs": {
      "t5": ["3", 0],
      "positive_prompt": "a person talking, realistic, high quality, clear face, natural lighting",
      "negative_prompt": "blurry, low quality, distorted face, unnatural movement"
    },
    "class_type": "WanVideoTextEncode",
    "_meta": { "title": "Text Encode (Prompts)" }
  },
  "6": {
    "inputs": {
      "image": "ruby.png",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": { "title": "Load Avatar Image" }
  },
  "8": {
    "inputs": {
      "wav2vec_model": ["2", 0],
      "audio_1": ["9", 0],
      "normalize_loudness": true,
      "num_frames": 81,
      "fps": 25.0,
      "audio_scale": 1.0,
      "audio_cfg_scale": 1.0,
      "multi_audio_type": "para"
    },
    "class_type": "MultiTalkWav2VecEmbeds",
    "_meta": { "title": "MultiTalk: Extract Audio Features" }
  },
  "9": {
    "inputs": {
      "audio": "input_audio.wav",
      "upload": "audio"
    },
    "class_type": "LoadAudio",
    "_meta": { "title": "Load Voice Audio" }
  },
  "10": {
    "inputs": {
      "vae": ["4", 0],
      "width": 480,
      "height": 480,
      "frame_window_size": 81,
      "motion_frame": 25,
      "force_offload": true,
      "colormatch": "disabled",
      "tiled_vae": true,
      "start_image": ["6", 0],
      "clip_embeds": ["15", 0]
    },
    "class_type": "WanVideoImageToVideoMultiTalk",
    "_meta": { "title": "MultiTalk: Encode Image + Setup" }
  },
  "11": {
    "inputs": {
      "model": ["1", 0],
      "text_embeds": ["5", 0],
      "image_embeds": ["10", 0],
      "multitalk_embeds": ["8", 0],
      "steps": 20,
      "cfg": 6.0,
      "shift": 8.0,
      "seed": 42,
      "force_offload": true,
      "scheduler": "dpm++",
      "riflex_freq_index": 0
    },
    "class_type": "WanVideoSampler",
    "_meta": { "title": "WanVideo Sampler (Generate)" }
  },
  "12": {
    "inputs": {
      "vae": ["4", 0],
      "samples": ["11", 0],
      "enable_vae_tiling": true,
      "tile_sample_min_height": 256,
      "tile_sample_min_width": 256,
      "tile_overlap_factor_height": 0.2,
      "tile_overlap_factor_width": 0.2,
      "auto_tile_size": true
    },
    "class_type": "WanVideoDecode",
    "_meta": { "title": "WanVideo Decode (VAE)" }
  },
  "13": {
    "inputs": {
      "images": ["12", 0],
      "filename_prefix": "infinitetalk_result",
      "format": "video/h264-mp4",
      "fps": 25.0
    },
    "class_type": "VHS_VideoCombine",
    "_meta": { "title": "Save Video" }
  },
  "14": {
    "inputs": {
      "model_name": "clip_vision_h.safetensors"
    },
    "class_type": "WanVideoCLIPVisionLoader",
    "_meta": { "title": "Load CLIP Vision" }
  },
  "15": {
    "inputs": {
      "clip_vision": ["14", 0],
      "image": ["6", 0]
    },
    "class_type": "WanVideoImageEncode",
    "_meta": { "title": "Encode Image (CLIP)" }
  }
}

