      "combine_embeds": "average",
      "force_offload": true
    },
    "class_type": "WanVideoClipVisionEncode",
    "_meta": { "title": "Encode Avatar (CLIP Vision)" }
  },
  "13": {
    "inputs": {
      "vae": ["4", 0],
      "width": 480,
      "height": 480,
